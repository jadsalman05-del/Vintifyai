{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node", "config": { "includeFiles": ["api/**", "index.html", "maintenance.html", "model*.jpg", "scripts/**"], "maxDuration": 60 } },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "maintenance.html", "use": "@vercel/static" },
    { "src": "model1.jpg", "use": "@vercel/static" },
    { "src": "model2.jpg", "use": "@vercel/static" },
    { "src": "model3.jpg", "use": "@vercel/static" },
    { "src": "model4.jpg", "use": "@vercel/static" },
    { "src": "model5.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/market", "dest": "/api/market.js" },
    { "src": "/api/imagegen", "dest": "/api/imagegen.js" },
    { "src": "/api/imagegen2", "dest": "/api/imagegen2.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/activate", "dest": "/api/activate.js" },
    { "src": "/api/suppliers", "dest": "/api/suppliers.js" },
    { "src": "/model[1-5]\\.jpg", "dest": "/$0" },
    { "src": "/(.*)", "dest": "/api/gate.js" }
  ]
}
